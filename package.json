{
  "name": "developers-quiz",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.2.23",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "lint": "eslint .",
    "preview": "astro preview",
    "format": "prettier --write",
    "start": "bun ./dist/server/entry.mjs",
    "questions:to-json": "bun scripts/questions-convert.ts --to-json --input questions.md --output src/data/questions.json",
    "questions:to-md": "bun scripts/questions-convert.ts --to-md --input src/data/questions.json --output questions.md"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.0",
    "@astrojs/react": "^4.4.0",
    "astro": "^5.8.0",
    "bootstrap": "^5.3.8",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.1",
    "mailgun.js": "^11.1.0",
    "react": "^19.2.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
